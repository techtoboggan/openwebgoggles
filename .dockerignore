docs/

# CI/CD (not needed in image)
.github/

# Node (SDK package artifacts)
assets/sdk/node_modules/
assets/sdk/package-lock.json
assets/sdk/yarn.lock

# macOS
.DS_Store

# Playwright test output
test-results/
playwright-report/
